import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int cp = sc.nextInt(); 
        int sp = sc.nextInt(); 

        double profitPercent = ((sp - cp) / (double)cp) * 100;

        System.out.printf("%.2f", profitPercent);

        sc.close();
    }
}
